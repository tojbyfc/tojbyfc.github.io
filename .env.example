# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# These vars are used by the local scripts (npm run seed / npm run update).
# For the GitHub Action, paste the same values into the repo's
# Settings → Secrets and variables → Actions instead.

FOOTBALL_DATA_TOKEN=your-football-data-token-here
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
